<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Login | EduVerse ERP</title>
  <link rel="stylesheet" href="/css/design-system.css">
  <link rel="stylesheet" href="/css/components.css">
  <link rel="stylesheet" href="/css/forms.css">
  <link rel="stylesheet" href="/css/auth.css">
</head>
<body>
  <div class="auth-page">
    <div class="auth-card">
      <div class="auth-logo">
        <div class="auth-logo-icon">🎓</div>
        <div class="auth-logo-text">EduVerse<span>School ERP + LMS</span></div>
      </div>
      <div class="auth-title">
        <h1>Welcome Back</h1>
        <p>Sign in with your User ID to continue</p>
      </div>
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="alert alert-danger">⚠️ <%= error %></div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="alert alert-success">✅ <%= success %></div>
      <% } %>
      <form method="POST" action="/login" id="loginForm">
        <div class="form-group">
          <label class="form-label" for="user_id">User ID</label>
          <input type="text" id="user_id" name="user_id" class="form-control" placeholder="Enter your User ID" autocomplete="username" required autofocus>
        </div>
        <div class="form-group">
          <label class="form-label" for="password">Password</label>
          <input type="password" id="password" name="password" class="form-control" placeholder="••••••••" autocomplete="current-password" required>
        </div>
        <button type="submit" class="btn btn-primary btn-lg w-full" id="loginBtn">Sign In</button>
      </form>
      <div class="auth-footer">
        Contact your administrator for account access.
      </div>
    </div>
  </div>
</body>
</html>
