<%- include('../partials/layout-top') %>

<div class="page-header">
  <div><h1>✅ Attendance Overview</h1><p class="page-header-subtitle">View and manage school-wide attendance</p></div>
</div>

<div class="card animate-fade-in">
  <div class="card-header"><h3>Select Class</h3></div>
  <div class="grid grid-auto-fill" style="padding: var(--space-4);">
    <% if (classes.length === 0) { %>
      <div class="empty-state"><div class="empty-state-icon">🏛️</div><h3>No Classes</h3><p>Create classes first to manage attendance.</p></div>
    <% } else { %>
      <% classes.forEach(c => { %>
      <a href="/admin/attendance?class_id=<%= c.id %>" class="quick-action-btn <%= selectedClass === c.id ? 'active' : '' %>">
        <span class="quick-action-icon">🏛️</span> <%= c.name %>
      </a>
      <% }) %>
    <% } %>
  </div>
</div>

<% if (selectedClass) { %>
<!-- Attendance Summary -->
<div class="card mt-6 animate-fade-in-up stagger-2">
  <div class="card-header"><h3>📊 Attendance for <%= selectedClassName %> — Today (<%= today %>)</h3></div>
  <div class="card-body">
    <div class="stats-grid" style="grid-template-columns: repeat(3, 1fr); margin-bottom: var(--space-6);">
      <div class="stat-card stat-success">
        <div class="stat-card-icon">✅</div>
        <div class="stat-card-value"><%= todayStats.present %></div>
        <div class="stat-card-label">Present Today</div>
      </div>
      <div class="stat-card stat-danger">
        <div class="stat-card-icon">❌</div>
        <div class="stat-card-value"><%= todayStats.absent %></div>
        <div class="stat-card-label">Absent Today</div>
      </div>
      <div class="stat-card stat-warning">
        <div class="stat-card-icon">⏰</div>
        <div class="stat-card-value"><%= todayStats.late %></div>
        <div class="stat-card-label">Late Today</div>
      </div>
    </div>

    <!-- Student List with Attendance -->
    <div class="table-wrapper">
      <table class="data-table">
        <thead>
          <tr><th>Student</th><th>User ID</th><th>Today</th><th>Total Present</th><th>Total Absent</th><th>Total Late</th><th>Attendance %</th></tr>
        </thead>
        <tbody>
          <% if (students.length === 0) { %>
            <tr><td colspan="7" style="text-align:center;padding:var(--space-8);color:var(--color-text-muted);">No students in this class.</td></tr>
          <% } else { %>
            <% students.forEach(s => { %>
            <tr>
              <td><div class="d-flex align-center gap-3"><div class="avatar avatar-sm"><%= (s.full_name || '?').substring(0,2).toUpperCase() %></div><strong><%= s.full_name %></strong></div></td>
              <td><span class="badge badge-info"><%= s.user_id %></span></td>
              <td>
                <% if (s.todayStatus === 'present') { %>
                  <span class="badge badge-success">Present</span>
                <% } else if (s.todayStatus === 'absent') { %>
                  <span class="badge badge-danger">Absent</span>
                <% } else if (s.todayStatus === 'late') { %>
                  <span class="badge badge-warning">Late</span>
                <% } else { %>
                  <span class="badge" style="background:var(--color-bg-tertiary);color:var(--color-text-muted);">Not Marked</span>
                <% } %>
              </td>
              <td style="color:var(--color-success);font-weight:600;"><%= s.presentCount %></td>
              <td style="color:var(--color-danger);font-weight:600;"><%= s.absentCount %></td>
              <td style="color:var(--color-warning);font-weight:600;"><%= s.lateCount %></td>
              <td>
                <% const total = s.presentCount + s.absentCount + s.lateCount; const pct = total > 0 ? Math.round((s.presentCount + s.lateCount) / total * 100) : 0; %>
                <div class="d-flex align-center gap-3">
                  <div class="progress-bar" style="flex:1;height:8px;background:var(--color-bg-tertiary);border-radius:4px;overflow:hidden;">
                    <div style="width:<%= pct %>%;height:100%;background:<%= pct >= 75 ? 'var(--color-success)' : pct >= 50 ? 'var(--color-warning)' : 'var(--color-danger)' %>;border-radius:4px;"></div>
                  </div>
                  <span style="font-weight:600;min-width:40px;"><%= pct %>%</span>
                </div>
              </td>
            </tr>
            <% }) %>
          <% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<% } else { %>
<div class="card mt-6 animate-fade-in-up stagger-2">
  <div class="card-body" style="text-align:center;padding:var(--space-10);">
    <div style="font-size:3rem;">📋</div>
    <h3 style="margin-top:var(--space-4);">Select a Class</h3>
    <p class="text-muted">Choose a class above to view attendance records.</p>
  </div>
</div>
<% } %>

<%- include('../partials/layout-bottom') %>
